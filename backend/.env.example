# ===========================================
# PetAI Backend 环境配置示例
# 复制此文件为 .env 并填入实际值
# ===========================================

# 应用配置
APP_NAME=PetAI Backend
APP_VERSION=1.0.0
DEBUG=true

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# CORS 配置（允许的前端域名，逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# Supabase 数据库配置
# 从 Supabase 控制台获取
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================================
# JWT 认证配置
# ===========================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# AI 服务配置
# ===========================================
# AI 提供商选择: gemini | openai | local
AI_PROVIDER=gemini

# Google Gemini API
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API（备选）
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# ===========================================
# Pet Vision Narrator 配置
# ===========================================
# 视频处理模式: local | api
PETVISION_MODE=api

# 本地模型配置（如果使用 local 模式）
PETVISION_LOCAL_MODEL=HuggingFaceTB/SmolVLM2-256M-Video-Instruct

# Ollama 配置（本地 LLM）
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 视频处理选项
PETVISION_USE_FRAME_SAMPLING=false
PETVISION_ENABLE_LLM_ANALYSIS=true
PETVISION_SAVE_DEBUG_OUTPUT=true

# ===========================================
# 3D 模型生成配置
# ===========================================
# 3D 生成服务: hunyuan | meshy | tripo | cloud | local
MODEL_3D_PROVIDER=hunyuan

# 混元 3D API (推荐)
# 混元生3D（专业版）OpenAI 兼容接口
# API Key: 从控制台 API Key 页面创建
HUNYUAN_API_KEY=your-hunyuan-api-key
HUNYUAN_API_URL=https://api.ai3d.cloud.tencent.com
# 模型版本: 3.0 或 3.1
HUNYUAN_MODEL=3.0

# Meshy AI API (备选)
MESHY_API_KEY=your-meshy-api-key

# Tripo AI API (备选)
TRIPO_API_KEY=your-tripo-api-key

# ===========================================
# 文件存储配置
# ===========================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=100
MODEL_3D_DIR=models_3d
